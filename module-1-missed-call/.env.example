# ─────────────────────────────────────────────────────────────────────────────
# SOURCE X — AI Operating System
# Environment Variables
#
# Copy this file to .env and fill in the values for your deployment.
# All values are optional — missing values fall back to simulation/demo mode.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development           # Set to "production" when deployed

# ── Clinic Configuration ──────────────────────────────────────────────────────
CLINIC_ID=northview            # Unique slug per client (no spaces)
CLINIC_NAME=Northview Medical Centre
CLINIC_PHONE=+14165550100
CLINIC_FAX=+14165550101
CLINIC_ADDRESS=1200 Sheppard Ave E, North York, ON M2K 2W4
CLINIC_TIMEZONE=America/Toronto
CLINIC_HOURS_START=8           # 8 AM
CLINIC_HOURS_END=17            # 5 PM
CLINIC_AVG_FEE=350             # Average appointment fee in dollars (for ROI reporting)

# Single provider (most common case)
CLINIC_PROVIDER_NAME=Dr. Anand Mehta
CLINIC_PROVIDER_SPECIALTY=Physiotherapy

# Multiple providers (JSON array — use instead of above two vars)
# CLINIC_PROVIDERS=[{"name":"Dr. Anand Mehta","specialty":"Physiotherapy"},{"name":"Dr. Sara Lee","specialty":"Chiropractic"}]

# ── Front Desk SMS Alert ───────────────────────────────────────────────────────
# This number receives the SMS booking alert after every AI call that results in a booking.
# Set to the clinic front desk phone number (or Vatsal's personal number for demo).
CLINIC_FRONT_DESK_NUMBER=+14165550199

# ── AI Agent ──────────────────────────────────────────────────────────────────
AGENT_NAME=Sarah               # Name the AI agent introduces itself with

# ── Vapi.ai — Live Outbound Calls ─────────────────────────────────────────────
# Create account at app.vapi.ai → get API key → create assistant → copy assistant ID.
# Without these, all calls run in simulation mode.
#
# SETUP STEPS:
#   1. app.vapi.ai → API Keys → copy key → set VAPI_API_KEY
#   2. Assistants → New → paste system prompt from build doc → copy ID → set VAPI_ASSISTANT_ID
#   3. Configure Analysis Plan in Vapi dashboard with this structuredDataSchema:
#      { "type": "object", "properties": {
#          "patient_name":   { "type": "string" },
#          "preferred_time": { "type": "string" },
#          "reason":         { "type": "string" },
#          "outcome":        { "type": "string", "enum": ["booked","declined","no_answer","voicemail"] }
#      }}
#   4. Set webhook URL in Vapi assistant → Server URL: https://YOUR_DOMAIN/api/vapi/webhook
#   5. PHONE NUMBER (choose one):
#      Option A — Use your Twilio number directly (no extra purchase):
#        Leave VAPI_PHONE_NUMBER_ID blank. Vapi will use TWILIO_* credentials below.
#      Option B — Vapi-managed number ($2/mo, simpler setup):
#        Phone Numbers → Buy number → copy ID → set VAPI_PHONE_NUMBER_ID
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=          # Optional — leave blank to use Twilio number directly

# ── Twilio — Missed Call Webhook + Outbound SMS ───────────────────────────────
# Webhook URL to set in Twilio console → Phone Numbers → your number → Voice:
#   https://YOUR_DOMAIN/api/twilio/voice  (Method: HTTP POST)
#
# Call Forwarding: clinic calls their carrier (Rogers/Bell/Telus) and says:
#   "Forward unanswered calls after 3 rings to [TWILIO_FROM_NUMBER]"
#   Takes 5 minutes. No hardware changes. No tech involvement from the clinic.
#
# PHIPA: Enable "Canadian Data Residency" in Twilio console → Account Settings.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+14165550100    # The clinic's dedicated Twilio number

# ── PHIPA Compliance — Encryption ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED for production — without this, patient PII is stored unencrypted.
ENCRYPTION_KEY=

# ── Database — PostgreSQL ─────────────────────────────────────────────────────
# REQUIRED for PHIPA audit tables (call_events, bookings_recovered, sms_events).
# Without this, data falls back to backend/data/calls.json (dev only).
# Railway: deploy to ca-central-1 region → add PostgreSQL plugin → copy DATABASE_URL.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ── Google Reviews (Module 6) ─────────────────────────────────────────────────
GOOGLE_PLACE_ID=               # From Google Business Profile
GOOGLE_REVIEW_URL=             # Direct link: https://g.page/r/YOUR_ID/review

# ── Airtable — Alternative to PostgreSQL (simpler setup, no PHIPA tables) ─────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Call Records

# ─────────────────────────────────────────────────────────────────────────────
# STORAGE PRIORITY: PostgreSQL > Airtable > JSON file
# CALL MODE PRIORITY: Vapi live > simulation
# ─────────────────────────────────────────────────────────────────────────────